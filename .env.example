# Database (Docker service name "db" as host)
DATABASE_URL="postgresql://postgres:postgres@db:5432/finance_dashboard"

# NextAuth / Auth.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_SECRET="generate-with-openssl-rand-base64-32"

# OAuth providers (optional - app works with email/password without these)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# AI Insights (optional - insights feature shows placeholder without this)
OPENAI_API_KEY=""
